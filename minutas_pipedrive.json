{
  "name": "Minutas de Reunión → Pipedrive",
  "flow": [
    {
      "id": 1,
      "module": "google-email:TriggerNewEmail",
      "version": 1,
      "parameters": {
        "__IMTCONN__": 8153044,
        "searchType": "gmail",
        "xGmRaw": "(to:agenda.virtual@nubceo.com OR cc:agenda.virtual@nubceo.com) (\"resumen\" OR \"minuta\" OR \"notas\") -invitación -invite -canceled -accepted -.ics",
        "markSeen": false,
        "maxResults": 10
      },
      "mapper": {},
      "metadata": {
        "designer": { "x": 0, "y": 0 },
        "restore": {
          "parameters": {
            "__IMTCONN__": {
              "data": { "scoped": "true", "connection": "google-email" },
              "label": "My Gmail connection"
            }
          }
        }
      }
    },
    {
      "id": 2,
      "module": "gemini-ai:simpleTextPrompt",
      "version": 1,
      "parameters": {},
      "mapper": {
        "model": "gemini-2.5-flash",
        "textPrompt": "Actúa como un experto en ventas B2B. A continuación te paso una minuta de una reunión. Tu tarea es analizar el texto y extraer la información solicitada completando esta estructura. Si algún dato no se menciona, escribe \"No especificado\".\n\nEstructura:\n- Fecha:\n- Participantes:\n- Cantidad de Sucursales:\n- Medios de Pagos:\n- Cantidad de transacciones mensuales:\n- ERP:\n- Punto de Venta:\n- Software para conciliar:\n- Terminales integradas:\n- Departamento de Sistemas:\n- Proceso de Control de las Tarjetas:\n- Principales Necesidades identificadas:\n- Puntos que destacó el cliente sobre Nubceo:\n- Beneficios que Nubceo le traería al cliente:\n- Pasos a seguir acordados con el cliente:\n\nMinuta de reunión:\n{{1.text}}",
        "systemPrompt": ""
      },
      "metadata": {
        "designer": { "x": 300, "y": 0 }
      }
    },
    {
      "id": 3,
      "module": "pipedrive:ActionSearchObjects",
      "version": 1,
      "parameters": {
        "__IMTCONN__": 7916818,
        "module": "persons",
        "continueWhenNoRes": false
      },
      "mapper": {
        "term": "{{1.from.address}}",
        "fields": "email",
        "exact_match": true
      },
      "metadata": {
        "designer": { "x": 600, "y": 0 },
        "restore": {
          "parameters": {
            "__IMTCONN__": {
              "data": { "scoped": "true", "connection": "pipedrive" },
              "label": "My Pipedrive connection"
            },
            "module": { "label": "Persons" }
          }
        }
      }
    },
    {
      "id": 4,
      "module": "pipedrive:ActionGetAllObjects",
      "version": 1,
      "parameters": {
        "__IMTCONN__": 7916818,
        "module": "deals",
        "continueWhenNoRes": false
      },
      "mapper": {},
      "metadata": {
        "designer": { "x": 900, "y": 0 },
        "restore": {
          "parameters": {
            "__IMTCONN__": {
              "data": { "scoped": "true", "connection": "pipedrive" },
              "label": "My Pipedrive connection"
            },
            "module": { "label": "Deals" }
          }
        }
      }
    },
    {
      "id": 5,
      "module": "pipedrive:ActionCreateObject",
      "version": 1,
      "parameters": {
        "__IMTCONN__": 7916818,
        "module": "notes"
      },
      "filter": {
        "name": "Deal abierto del contacto",
        "conditions": [
          [
            {
              "a": "{{4.person_id.value}}",
              "b": "{{3.id}}",
              "o": "number:equal"
            },
            {
              "a": "{{4.status}}",
              "b": "open",
              "o": "text:equal"
            }
          ]
        ]
      },
      "mapper": {
        "content": "{{2.result}}",
        "deal_id": "{{4.id}}",
        "person_id": "{{3.id}}",
        "pinned_to_deal_flag": true
      },
      "metadata": {
        "designer": { "x": 1200, "y": 0 },
        "restore": {
          "parameters": {
            "__IMTCONN__": {
              "data": { "scoped": "true", "connection": "pipedrive" },
              "label": "My Pipedrive connection"
            },
            "module": { "label": "Notes" }
          }
        }
      }
    }
  ],
  "metadata": {
    "instant": false,
    "version": 1,
    "scenario": {
      "roundtrips": 1,
      "maxErrors": 3,
      "autoCommit": true,
      "autoCommitTriggerLast": true,
      "sequential": false,
      "slots": null,
      "confidential": false,
      "dataloss": false,
      "dlq": false,
      "freshVariables": false
    },
    "designer": { "orphans": [] },
    "zone": "us2.make.com"
  }
}
