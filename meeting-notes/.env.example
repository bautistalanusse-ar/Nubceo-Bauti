# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Gmail OAuth2 Credentials (desde Google Cloud Console)
# Seguir las instrucciones en setup-oauth.js para obtener estos valores
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob

# Tokens de acceso (se generan con: npm run setup-oauth)
GOOGLE_ACCESS_TOKEN=ya29...
GOOGLE_REFRESH_TOKEN=1//...

# Configuración Nubceo
NUBCEO_EMAIL=agenda.virtual@nubceo.com
NUBCEO_DOMAIN=nubceo.com

# Zona horaria para el cron (6pm Argentina = UTC-3)
TZ=America/Argentina/Buenos_Aires
